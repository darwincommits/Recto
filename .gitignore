# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# AI-driven gitscript convention (Hard Rule #10): one-shot push scripts
# written at repo root, executed once, deleted by the operator. Belt-and-
# suspenders gitignore so a forgotten cleanup doesn't accidentally land
# in a future commit. Both the conventional default name and the operator-
# preferred alias are covered.
git_push.ps1
gitscript.ps1

