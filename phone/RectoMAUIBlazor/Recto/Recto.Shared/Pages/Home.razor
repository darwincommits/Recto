    private async Task ApproveTotpProvisionAsync(PendingRequest req)
    {
        if (string.IsNullOrEmpty(req.Context.TotpAlias) || string.IsNullOrEmpty(req.Context.TotpSecretB32))
        {
            _pollingError = "totp_provision request missing totp_alias or totp_secret_b32.";
            return;
        }
        _processingText = "Storing secret...";
        StateHasChanged();
        await Task.Yield();
        var provisionResult = await Totp.ProvisionAsync(
            req.Context.TotpAlias,
            req.Context.TotpSecretB32,
            req.Context.TotpPeriodSeconds ?? 30,
            req.Context.TotpDigits ?? 6,
            req.Context.TotpAlgorithm ?? "SHA1",
            CancellationToken.None);
        if (provisionResult.IsFailure)
        {
            _pollingError = provisionResult.Error.Message;
            return;
        }
        _processingText = "Sending response...";
        StateHasChanged();
        var respondReq = new RespondRequest(
            PhoneId: _paired!.PhoneId,
            Decision: RespondDecision.Approved);
        var respondResult = await BootloaderClient.RespondAsync(
            _paired.BootloaderUrl, req.RequestId, respondReq, CancellationToken.None);
        if (respondResult.IsFailure)
        {
            _pollingError = respondResult.Error.Message;
            return;
        }
        await RefreshPendingAsync(CancellationToken.None);
    }

    private async Task ApproveTotpGenerateAsync(PendingRequest req)
    {
        if (string.IsNullOrEmpty(req.Context.TotpAlias))
        {
            _pollingError = "totp_generate request missing totp_alias.";
            return;
        }
        _processingText = "Generating code...";
        StateHasChanged();
        await Task.Yield();
        var codeResult = await Totp.GenerateAsync(req.Context.TotpAlias, CancellationToken.None);
        if (codeResult.IsFailure)
        {
            _pollingError = codeResult.Error.Message;
            return;
        }
        _processingText = "Sending response...";
        StateHasChanged();
        var respondReq = new RespondRequest(
            PhoneId: _paired!.PhoneId,
            Decision: RespondDecision.Approved,
            TotpCode: codeResult.Value);
        var respondResult = await BootloaderClient.RespondAsync(
            _paired.BootloaderUrl, req.RequestId, respondReq, CancellationToken.None);
        if (respondResult.IsFailure)
        {
            _pollingError = respondResult.Error.Message;
            return;
        }
        _lastTotpCode = codeResult.Value;
        _lastTotpAlias = req.Context.TotpAlias;
        _lastTotpAt = DateTimeOffset.UtcNow;
        _totpCopied = false;
        await RefreshPendingAsync(CancellationToken.None);
    }

    private async Task ApproveSessionIssuanceAsync(PendingRequest req)
    {
        if (string.IsNullOrEmpty(req.Context.SessionBearer)
            || string.IsNullOrEmpty(req.Context.SessionBootloaderId)
            || (req.Context.SessionLifetimeSeconds ?? 0) <= 0
            || (req.Context.SessionMaxUses ?? 0) <= 0
            || req.Context.SessionScope is not { Count: > 0 })
        {
            _pollingError = "session_issuance request missing required context fields.";
            return;
        }
        _processingText = "Awaiting biometric...";
        StateHasChanged();
        await Task.Yield();
        var pubResult = await EnclaveKeys.GetPublicKeyAsync(KeyAlias, CancellationToken.None);
        if (pubResult.IsFailure)
        {
            _pollingError = pubResult.Error.Message;
            return;
        }
        var iss = CapabilityJwtBuilder.Fingerprint(pubResult.Value.PublicKey);
        var now = DateTimeOffset.UtcNow.ToUnixTimeSeconds();
        var claims = new CapabilityJwtClaims(
            Iss: iss,
            Sub: $"{req.Service}:{req.Secret}",
            Aud: req.Context.SessionBootloaderId!,
            Exp: now + req.Context.SessionLifetimeSeconds!.Value,
            Iat: now,
            Jti: Guid.NewGuid().ToString(),
            Scope: req.Context.SessionScope!,
            MaxUses: req.Context.SessionMaxUses!.Value,
            Bearer: req.Context.SessionBearer!);
        _processingText = "Signing JWT...";
        StateHasChanged();
        await Task.Yield();
        var jwtResult = await CapabilityJwtBuilder.BuildAsync(
            EnclaveKeys, KeyAlias, claims, CancellationToken.None);
        if (jwtResult.IsFailure)
        {
            _pollingError = jwtResult.Error.Message;
            return;
        }
        _processingText = "Sending response...";
        StateHasChanged();
        var respondReq = new RespondRequest(
            PhoneId: _paired!.PhoneId,
            Decision: RespondDecision.Approved,
            SessionJwt: jwtResult.Value);
        var respondResult = await BootloaderClient.RespondAsync(
            _paired.BootloaderUrl, req.RequestId, respondReq, CancellationToken.None);
        if (respondResult.IsFailure)
        {
            _pollingError = respondResult.Error.Message;
            return;
        }
        await RefreshPendingAsync(CancellationToken.None);
    }

    private async Task ApproveWebAuthnAssertAsync(PendingRequest req)
    {
        if (string.IsNullOrEmpty(req.Context.WebAuthnRpId)
            || string.IsNullOrEmpty(req.Context.WebAuthnOrigin)
            || string.IsNullOrEmpty(req.Context.WebAuthnChallengeB64u))
        {
            _pollingError = "webauthn_assert request missing required context fields.";
            return;
        }
        _processingText = "Awaiting biometric...";
        StateHasChanged();
        await Task.Yield();

        var assertionResult = await WebAuthnAssertionBuilder.BuildAsync(
            EnclaveKeys,
            KeyAlias,
            req.Context.WebAuthnRpId!,
            req.Context.WebAuthnOrigin!,
            req.Context.WebAuthnChallengeB64u!,
            counter: 0,
            CancellationToken.None);
        if (assertionResult.IsFailure)
        {
            _pollingError = assertionResult.Error.Message;
            return;
        }

        _processingText = "Sending assertion...";
        StateHasChanged();
        var respondReq = new RespondRequest(
            PhoneId: _paired!.PhoneId,
            Decision: RespondDecision.Approved,
            SignatureB64u: assertionResult.Value.SignatureB64u,
            WebAuthnClientDataB64u: assertionResult.Value.ClientDataB64u,
            WebAuthnAuthenticatorDataB64u: assertionResult.Value.AuthenticatorDataB64u);
        var respondResult = await BootloaderClient.RespondAsync(
            _paired.BootloaderUrl, req.RequestId, respondReq, CancellationToken.None);
        if (respondResult.IsFailure)
        {
            _pollingError = respondResult.Error.Message;
            return;
        }
        await RefreshPendingAsync(CancellationToken.None);
    }

    private async Task HandleDenyAsync(PendingRequest req)
    {
        if (_paired is null) return;
        _processingRequestId = req.RequestId;
        _processingText = "Denying...";
        StateHasChanged();
        try
        {
            var respondReq = new RespondRequest(
                PhoneId: _paired.PhoneId,
                Decision: RespondDecision.Denied,
                Reason: "operator declined");
            var respondResult = await BootloaderClient.RespondAsync(
                _paired.BootloaderUrl, req.RequestId, respondReq, CancellationToken.None);
            if (respondResult.IsFailure)
            {
                _pollingError = respondResult.Error.Message;
                return;
            }
            await RefreshPendingAsync(CancellationToken.None);
        }
        finally
        {
            _processingRequestId = null;
            _processingText = string.Empty;
            StateHasChanged();
        }
    }

    // --- Round 7 phone management ---

    private async Task RefreshRegisteredPhonesAsync(CancellationToken ct)
    {
        if (_paired is null) return;
        _refreshingPhones = true;
        StateHasChanged();
        try
        {
            var result = await BootloaderClient.ListRegisteredPhonesAsync(
                _paired.BootloaderUrl, _paired.PhoneId, ct);
            if (result.IsSuccess)
            {
                _registeredPhones = result.Value.Phones.ToList();
            }
            else
            {
                // Surface in the same poll-error slot used for pending refresh.
                _pollingError = result.Error.Message;
            }
        }
        finally
        {
            _refreshingPhones = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task HandleRevokeAsync(RegisteredPhoneInfo target)
    {
        if (_paired is null) return;

        // Confirm via the browser-native confirm dialog so an accidental tap
        // doesn't nuke a backup phone.
        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            $"Revoke '{target.DeviceLabel}'?\n\nThis phone will no longer be able to sign requests for this bootloader. " +
            $"You can re-pair it later if needed.");
        if (!confirmed) return;

        _revokingPhoneId = target.PhoneId;
        _revokingText = "Awaiting biometric...";
        StateHasChanged();

        try
        {
            // Step 1: fetch a fresh challenge to sign as the auth proof.
            var challengeResult = await BootloaderClient.GetRevokeChallengeAsync(
                _paired.BootloaderUrl, _paired.PhoneId, CancellationToken.None);
            if (challengeResult.IsFailure)
            {
                _pollingError = challengeResult.Error.Message;
                return;
            }
            var challenge = challengeResult.Value;

            // Step 2: sign the challenge bytes with the enclave key. iOS / Android
            // trigger biometric here; Windows-software signs immediately.
            var challengeBytes = Base64UrlDecode(challenge.ChallengeB64u);
            var signResult = await EnclaveKeys.SignAsync(KeyAlias, challengeBytes, CancellationToken.None);
            if (signResult.IsFailure)
            {
                _pollingError = signResult.Error.Message;
                return;
            }

            // Step 3: POST the revocation.
            _revokingText = "Revoking...";
            StateHasChanged();
            await Task.Yield();
            var revokeReq = new RevokeRequest(
                RevokingPhoneId: _paired.PhoneId,
                TargetPhoneId: target.PhoneId,
                Challenge: challenge.ChallengeB64u,
                SignatureB64u: Base64UrlEncode(signResult.Value));
            var revokeResult = await BootloaderClient.RevokePhoneAsync(
                _paired.BootloaderUrl, revokeReq, CancellationToken.None);
            if (revokeResult.IsFailure)
            {
                _pollingError = revokeResult.Error.Message;
                return;
            }

            // Step 4: refresh the list so the revoked phone disappears.
            await RefreshRegisteredPhonesAsync(CancellationToken.None);
        }
        finally
        {
            _revokingPhoneId = null;
            _revokingText = string.Empty;
            StateHasChanged();
        }
    }

    private async Task CopyTotpCodeAsync()
    {
        if (string.IsNullOrEmpty(_lastTotpCode)) return;
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _lastTotpCode);
            _totpCopied = true;
            StateHasChanged();
            // Reset the "Copied" indicator after 2 s so a subsequent generation
            // gets a fresh "Copy" affordance.
            await Task.Delay(2000);
            _totpCopied = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _pollingError = $"Clipboard copy failed: {ex.Message}";
        }
    }

    // --- Polling ---

    private void StartPolling()
    {
        StopPolling();
        _pollCts = new CancellationTokenSource();
        _ = PollLoopAsync(_pollCts.Token);
    }

    private void StopPolling()
    {
        try { _pollCts?.Cancel(); } catch { /* swallow */ }
        _pollCts?.Dispose();
        _pollCts = null;
    }

    private async Task PollLoopAsync(CancellationToken ct)
    {
        while (!ct.IsCancellationRequested)
        {
            await RefreshPendingAsync(ct);
            try
            {
                await Task.Delay(PollInterval, ct);
            }
            catch (OperationCanceledException)
            {
                return;
            }
        }
    }

    private async Task RefreshPendingAsync(CancellationToken ct)
    {
        if (_paired is null) return;
        var result = await BootloaderClient.GetPendingAsync(_paired.BootloaderUrl, _paired.PhoneId, ct);
        if (result.IsSuccess)
        {
            _pending = result.Value.Requests.ToList();
            _pollingError = null;
            await PopulateEthAddressesAsync(_pending, ct);
            await PopulateBtcAddressesAsync(_pending, ct);
        }
        else
        {
            _pollingError = result.Error.Message;
        }
        await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Pre-derive the ETH address each pending <c>eth_sign</c> request
    /// will sign with, keyed by request_id. This runs once per refresh
    /// (~2-5 ms per address on Windows) so the @switch render arm can
    /// show "Address: 0x..." inline without doing async work in markup.
    /// Stale entries from previous refreshes are dropped.
    /// </summary>
    private async Task PopulateEthAddressesAsync(List<PendingRequest> pending, CancellationToken ct)
    {
        var newMap = new Dictionary<string, string>();
        foreach (var req in pending)
        {
            if (req.Kind != PendingRequestKind.EthSign) continue;
            var path = string.IsNullOrEmpty(req.Context.EthDerivationPath)
                ? "m/44'/60'/0'/0/0"
                : req.Context.EthDerivationPath!;
            var account = await EthSigner.EnsureMnemonicAsync(EthKeyAlias, path, ct);
            if (account.IsSuccess)
            {
                newMap[req.RequestId] = account.Value.Address;
            }
        }
        _ethAddressByRequestId = newMap;
    }

    /// <summary>
    /// Wave-5 sibling of PopulateEthAddressesAsync. Runs once per
    /// refresh; for each pending btc_sign request, derives the
    /// network-and-path-specific Bitcoin address (bech32 P2WPKH for
    /// the m/84' purpose level) so the render arm can display
    /// "Address: bc1q..." inline without doing async work in markup.
    /// </summary>
    private async Task PopulateBtcAddressesAsync(List<PendingRequest> pending, CancellationToken ct)
    {
        var newMap = new Dictionary<string, string>();
        foreach (var req in pending)
        {
            if (req.Kind != PendingRequestKind.BtcSign) continue;
            var path = string.IsNullOrEmpty(req.Context.BtcDerivationPath)
                ? "m/84'/0'/0'/0/0"
                : req.Context.BtcDerivationPath!;
            var network = string.IsNullOrEmpty(req.Context.BtcNetwork)
                ? "mainnet"
                : req.Context.BtcNetwork!;
            var account = await BtcSigner.EnsureMnemonicAsync(BtcKeyAlias, path, network, ct);
            if (account.IsSuccess)
            {
                newMap[req.RequestId] = account.Value.Address;
            }
        }
        _btcAddressByRequestId = newMap;
    }

    private async Task HandleRetryPollAsync()
    {
        _retrying = true;
        StateHasChanged();
        try
        {
            await RefreshPendingAsync(CancellationToken.None);
        }
        finally
        {
            _retrying = false;
            StateHasChanged();
        }
    }

    private async Task SetBusyTextAsync(string text)
    {
        _busyText = text;
        StateHasChanged();
        await Task.Yield();
    }

    public async ValueTask DisposeAsync()
    {
        StopPolling();
        await Task.CompletedTask;
    }

    // --- Cert pinning helpers ---

    private string? TryCaptureBootloaderPin(string bootloaderUrl)
    {
        try
        {
            var host = new Uri(bootloaderUrl).Host;
            var observed = Pinning.GetObservedPin(host);
            if (string.IsNullOrEmpty(observed)) return null;
            Pinning.SetPin(host, observed);
            return observed;
        }
        catch
        {
            return null;
        }
    }

    private void RestorePin(PairingState state)
    {
        if (string.IsNullOrEmpty(state.BootloaderSpkiPin)) return;
        try
        {
            var host = new Uri(state.BootloaderUrl).Host;
            Pinning.SetPin(host, state.BootloaderSpkiPin);
        }
        catch { /* ignore bad URL in stored state */ }
    }

    private void ClearPin(string bootloaderUrl)
    {
        try
        {
            var host = new Uri(bootloaderUrl).Host;
            Pinning.ClearPin(host);
        }
        catch { /* ignore */ }
    }

    // --- base64url helpers ---

    private static string Base64UrlEncode(byte[] data)
    {
        var b64 = Convert.ToBase64String(data);
        return b64.TrimEnd('=').Replace('+', '-').Replace('/', '_');
    }

    private static byte[] Base64UrlDecode(string b64u)
    {
        var b64 = b64u.Replace('-', '+').Replace('_', '/');
        switch (b64.Length % 4)
        {
            case 2: b64 += "=="; break;
            case 3: b64 += "="; break;
        }
        return Convert.FromBase64String(b64);
    }

    private static string TruncateHash(string hash) =>
        hash.Length > 16 ? hash[..16] + "..." : hash;

    private static string TruncatePin(string pin) =>
        pin.Length > 12 ? pin[..12] + "..." : pin;

