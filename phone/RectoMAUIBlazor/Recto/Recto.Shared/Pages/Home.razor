    // ---------------------------------------------------------------
    // Operator-facing summaries for EIP-712 typed data + EIP-1559
    // transactions. Best-effort parsing — if the JSON shape is wrong
    // (malformed, missing fields), the UI still renders the raw JSON
    // in the <details> dropdown so the operator can inspect manually.
    // ---------------------------------------------------------------

    private record EthTypedDataSummary(
        string PrimaryType,
        string? DomainName,
        string? DomainVersion,
        string? VerifyingContract);

    private static EthTypedDataSummary _ethTypedDataSummary(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return new("(unknown)", null, null, null);
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            var root = doc.RootElement;
            string primaryType = root.TryGetProperty("primaryType", out var pt) ? (pt.GetString() ?? "(unknown)") : "(unknown)";
            string? domainName = null, domainVersion = null, verifyingContract = null;
            if (root.TryGetProperty("domain", out var dom) && dom.ValueKind == System.Text.Json.JsonValueKind.Object)
            {
                if (dom.TryGetProperty("name", out var n)) domainName = n.GetString();
                if (dom.TryGetProperty("version", out var v)) domainVersion = v.GetString();
                if (dom.TryGetProperty("verifyingContract", out var vc)) verifyingContract = vc.GetString();
            }
            return new(primaryType, domainName, domainVersion, verifyingContract);
        }
        catch
        {
            return new("(parse error)", null, null, null);
        }
    }

    private record EthTransactionSummary(
        string? To,
        string? ValueDisplay,
        string? GasDisplay,
        string? MaxFeeDisplay,
        string? DataPreview);

    private static EthTransactionSummary _ethTransactionSummary(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return new(null, null, null, null, null);
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            var root = doc.RootElement;
            string? to = root.TryGetProperty("to", out var toEl) ? toEl.GetString() : null;
            string? valueDisplay = _formatWeiField(root, "value");
            string? gasDisplay = null;
            if (root.TryGetProperty("gas", out var g)) gasDisplay = _readNumberField(g);
            else if (root.TryGetProperty("gasLimit", out var gl)) gasDisplay = _readNumberField(gl);
            string? maxFeeDisplay = root.TryGetProperty("maxFeePerGas", out var mf)
                ? _formatGwei(_readNumberField(mf))
                : null;
            string? dataPreview = null;
            if (root.TryGetProperty("data", out var d) && d.ValueKind == System.Text.Json.JsonValueKind.String)
            {
                var s = d.GetString() ?? "";
                if (!string.IsNullOrEmpty(s) && s != "0x")
                {
                    dataPreview = s.Length > 24 ? s[..24] + "..." : s;
                }
            }
            return new(to, valueDisplay, gasDisplay, maxFeeDisplay, dataPreview);
        }
        catch
        {
            return new(null, null, null, null, null);
        }
    }

    private static string? _readNumberField(System.Text.Json.JsonElement el)
    {
        if (el.ValueKind == System.Text.Json.JsonValueKind.Number) return el.GetInt64().ToString();
        if (el.ValueKind == System.Text.Json.JsonValueKind.String) return el.GetString();
        return null;
    }

    private static string? _formatWeiField(System.Text.Json.JsonElement root, string fieldName)
    {
        if (!root.TryGetProperty(fieldName, out var el)) return null;
        var raw = _readNumberField(el);
        if (string.IsNullOrEmpty(raw)) return null;
        try
        {
            var wei = raw.StartsWith("0x", StringComparison.OrdinalIgnoreCase)
                ? System.Numerics.BigInteger.Parse("0" + raw[2..], System.Globalization.NumberStyles.HexNumber)
                : System.Numerics.BigInteger.Parse(raw);
            // Display in ETH if >= 1e15 wei (0.001 ETH), gwei otherwise.
            var oneEth = System.Numerics.BigInteger.Pow(10, 18);
            var oneGwei = System.Numerics.BigInteger.Pow(10, 9);
            if (wei >= oneEth / 1000)
            {
                var ethWhole = wei / oneEth;
                var ethFrac = (wei % oneEth) * 1000000 / oneEth;
                return $"{ethWhole}.{ethFrac:D6} ETH ({raw} wei)";
            }
            else if (wei > 0)
            {
                var gwei = wei / oneGwei;
                return $"{gwei} gwei ({raw} wei)";
            }
            return "0 wei";
        }
        catch
        {
            return raw + " wei";
        }
    }

    private static string? _formatGwei(string? raw)
    {
        if (string.IsNullOrEmpty(raw)) return null;
        try
        {
            var wei = raw.StartsWith("0x", StringComparison.OrdinalIgnoreCase)
                ? System.Numerics.BigInteger.Parse("0" + raw[2..], System.Globalization.NumberStyles.HexNumber)
                : System.Numerics.BigInteger.Parse(raw);
            var oneGwei = System.Numerics.BigInteger.Pow(10, 9);
            if (wei == 0) return "0 gwei";
            var gwei = wei / oneGwei;
            var rem = wei % oneGwei;
            if (rem == 0) return $"{gwei} gwei";
            return $"{gwei}.{(rem * 1000 / oneGwei):D3} gwei";
        }
        catch
        {
            return raw + " wei";
        }
    }
}
