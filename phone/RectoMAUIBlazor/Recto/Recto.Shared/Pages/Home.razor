@page "/"
@using System
@using System.Linq
@using System.Threading
@using Microsoft.JSInterop
@using Recto.Shared.Common
@using Recto.Shared.Models
@using Recto.Shared.Protocol.V04
@using Recto.Shared.Services
@implements IAsyncDisposable
@inject IFormFactor FormFactor
@inject IBootloaderClient BootloaderClient
@inject IEnclaveKeyService EnclaveKeys
@inject ITotpService Totp
@inject IEthSignService EthSigner
@inject IBtcSignService BtcSigner
@inject IPinningService Pinning
@inject IPairingStateService Pairing
@inject IPushTokenService PushTokens
@inject IJSRuntime JS

<PageTitle>Recto</PageTitle>

@*
    Recto vault — phone-side approval surface.

    Pending requests split into two semantic sections: IDENTITY &
    ACCESS (single_sign / TOTP / WebAuthn / JWT capability / PKCS#11
    / PGP — the "common security" credential kinds that authenticate
    the operator or sign small non-financial payloads) and CRYPTO
    TOKENS (eth_sign / btc_sign + family — cryptocurrency-custody
    credential kinds that move money or on-chain authority). The
    split is driven by IsTokenSigningKind() in @code; adding a new
    kind needs one switch arm + one entry there.

    Settings gear is now in MainLayout's topbar. Brand wordmark
    lives there too, so this page just carries the tagline + paired
    state + pending-request sections.
*@

<div class="rec-home">
    <p class="rec-tagline">Phone-resident vault for your services' secrets.</p>

    @if (_paired is not null)
    {
        <div class="card shadow-sm" style="max-width: 32rem; width: 100%;">
            <div class="card-body p-4">
                <h2 class="h5 mb-3 text-success">Paired</h2>
                <p class="text-muted small mb-3">
                    This phone is paired with the bootloader at
                    <code>@_paired.BootloaderUrl</code>.
                </p>
                <dl class="small text-start text-muted mb-3">
                    <dt class="fw-normal">Bootloader id</dt>
                    <dd class="text-break"><code>@_paired.BootloaderId</code></dd>
                    <dt class="fw-normal">Phone id</dt>
                    <dd class="text-break"><code>@_paired.PhoneId</code></dd>
                    <dt class="fw-normal">Algorithm</dt>
                    <dd><code>@EnclaveKeys.Algorithm</code></dd>
                    <dt class="fw-normal">TLS pin</dt>
                    <dd class="text-break">
                        @if (string.IsNullOrEmpty(_paired.BootloaderSpkiPin))
                        {
                            <span class="text-warning">none (system trust only)</span>
                        }
                        else
                        {
                            <code>@TruncatePin(_paired.BootloaderSpkiPin)</code>
                        }
                    </dd>
                    <dt class="fw-normal">Paired at</dt>
                    <dd>@_paired.PairedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</dd>
                </dl>
                @if (_paired.ManagedSecrets.Count > 0)
                {
                    <div class="text-start small mb-3">
                        <p class="mb-1 fw-semibold">Managed secrets (@_paired.ManagedSecrets.Count)</p>
                        <ul class="list-unstyled mb-0">
                            @foreach (var secret in _paired.ManagedSecrets)
                            {
                                <li class="text-muted"><code>@secret.Service</code>/<code>@secret.Secret</code> &mdash; @secret.Algorithm</li>
                            }
                        </ul>
                    </div>
                }

                @{
                    var totpFresh = _lastTotpAt is not null
                        && (DateTimeOffset.UtcNow - _lastTotpAt.Value).TotalSeconds < 30
                        && _lastTotpCode is not null;
                }
                @if (totpFresh)
                {
                    <div class="alert alert-info text-center my-3 mb-0" role="alert">
                        <p class="small text-muted mb-1">Last generated TOTP for <code>@_lastTotpAlias</code></p>
                        <p class="display-6 fw-bold mb-1" style="letter-spacing: 0.2em; font-variant-numeric: tabular-nums;">@_lastTotpCode</p>
                        <div class="d-flex align-items-center justify-content-center gap-2 mt-1">
                            <button type="button" class="btn btn-sm btn-outline-primary"
                                    @onclick="() => CopyTotpCodeAsync()">
                                @if (_totpCopied)
                                {
                                    <span>&#10003; Copied</span>
                                }
                                else
                                {
                                    <span>Copy</span>
                                }
                            </button>
                            <span class="small text-muted">
                                Valid for ~@(Math.Max(0, 30 - (int)(DateTimeOffset.UtcNow - _lastTotpAt!.Value).TotalSeconds))s
                            </span>
                        </div>
                    </div>
                }

                <hr class="my-3" />

                @if (!string.IsNullOrEmpty(_pollingError))
                {
                    <div class="alert alert-warning small text-start mb-3 d-flex align-items-start gap-2" role="alert">
                        <div class="flex-grow-1">
                            <strong>Couldn't reach the bootloader.</strong>
                            <div class="text-muted">@_pollingError</div>
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-secondary"
                                @onclick="HandleRetryPollAsync"
                                disabled="@_retrying">
                            @(_retrying ? "Retrying..." : "Retry")
                        </button>
                        <button type="button" class="btn-close ms-1" aria-label="Dismiss"
                                @onclick="() => _pollingError = null"></button>
                    </div>
                }

                <div class="rec-pending text-start small">
                    <div class="rec-pending-header">
                        <span class="rec-pending-title">Pending requests</span>
                        @if (_pending.Count > 0)
                        {
                            <span class="badge bg-primary">@_pending.Count</span>
                        }
                    </div>

                    @if (_pending.Count == 0)
                    {
                        <div class="rec-empty">
                            <div class="rec-empty-mark">&#10003;</div>
                            <div class="rec-empty-line">All caught up</div>
                            <div class="rec-empty-sub">Nothing waiting for your approval.</div>
                        </div>
                    }
                    else
                    {
                        // Per-request card body lives in a single
                        // RenderFragment template so both sections share
                        // one source of truth. We're already in C# context
                        // inside the else { } block, so no @{ } wrapper
                        // is needed (Razor RZ1010: "you do not need to
                        // use @{ to switch to code").
                        RenderFragment<PendingRequest> renderCard = (PendingRequest req) =>
                            @<div class="rec-pending-card" data-kind="@req.Kind">
                                <div class="rec-pending-card-body">
                                    @switch (req.Kind)
                                    {
                                        case PendingRequestKind.SingleSign:
                                            <p class="mb-1 fw-semibold">
                                                <span class="badge bg-secondary me-1">sign</span>@req.Context.OperationDescription
                                            </p>
                                            <p class="mb-1 text-muted small"><code>@req.Service</code>/<code>@req.Secret</code></p>
                                            <p class="mb-1 text-muted small">
                                                Hash: <code>@TruncateHash(req.Context.PayloadHashB64u ?? "")</code>
                                            </p>
                                            <p class="mb-2 text-muted small">
                                                From PID @req.Context.ChildPid (<code>@req.Context.ChildArgv0</code>)
                                            </p>
                                            break;
                                        case PendingRequestKind.TotpProvision:
                                            <p class="mb-1 fw-semibold">
                                                <span class="badge bg-warning text-dark me-1">TOTP</span>Provision secret
                                            </p>
                                            <p class="mb-1 text-muted small">
                                                Alias: <code>@req.Context.TotpAlias</code>
                                            </p>
                                            <p class="mb-1 text-muted small">@req.Context.OperationDescription</p>
                                            <p class="mb-2 text-muted small">
                                                Period: @(req.Context.TotpPeriodSeconds ?? 30)s,
                                                digits: @(req.Context.TotpDigits ?? 6),
                                                alg: @(req.Context.TotpAlgorithm ?? "SHA1")
                                            </p>
                                            break;
                                        case PendingRequestKind.TotpGenerate:
                                            <p class="mb-1 fw-semibold">
                                                <span class="badge bg-info text-dark me-1">TOTP</span>Generate code
                                            </p>
                                            <p class="mb-1 text-muted small">
                                                Alias: <code>@req.Context.TotpAlias</code>
                                            </p>
                                            <p class="mb-2 text-muted small">@req.Context.OperationDescription</p>
                                            break;
                                        case PendingRequestKind.SessionIssuance:
                                            <p class="mb-1 fw-semibold">
                                                <span class="badge bg-success me-1">capability</span>Issue JWT
                                            </p>
                                            <p class="mb-1 text-muted small">
                                                <code>@req.Service</code>/<code>@req.Secret</code> &rarr;
                                                bearer <code>@(req.Context.SessionBearer ?? "?")</code>
                                            </p>
                                            <p class="mb-1 text-muted small">@req.Context.OperationDescription</p>
                                            <p class="mb-2 text-muted small">
                                                Lifetime: @((req.Context.SessionLifetimeSeconds ?? 0) / 3600)h,
                                                max uses: @(req.Context.SessionMaxUses ?? 0),
                                                scope: @(req.Context.SessionScope is { Count: > 0 } s ? string.Join(", ", s) : "(none)")
                                            </p>
                                            break;
                                        case PendingRequestKind.WebAuthnAssert:
                                            <p class="mb-1 fw-semibold">
                                                <span class="badge bg-primary me-1">passkey</span>Sign in with Recto
                                            </p>
                                            <p class="mb-1 text-muted small">
                                                Site: <code>@(req.Context.WebAuthnRpId ?? "?")</code>
                                            </p>
                                            <p class="mb-1 text-muted small">
                                                Origin: <code>@(req.Context.WebAuthnOrigin ?? "?")</code>
                                            </p>
                                            <p class="mb-2 text-muted small">@req.Context.OperationDescription</p>
                                            break;
                                        case PendingRequestKind.Pkcs11Sign:
                                            <p class="mb-1 fw-semibold">
                                                <span class="badge bg-dark me-1">PKCS#11</span>@(_pkcs11PurposeLabel(req.Context.Purpose))
                                            </p>
                                            @if (!string.IsNullOrEmpty(req.Context.Pkcs11ConsumerLabel))
                                            {
                                                <p class="mb-1 text-muted small">
                                                    Consumer: <code>@req.Context.Pkcs11ConsumerLabel</code>
                                                </p>
                                            }
                                            <p class="mb-1 text-muted small">
                                                Hash: <code>@TruncateHash(req.Context.PayloadHashB64u ?? "")</code>
                                            </p>
                                            <p class="mb-2 text-muted small">@req.Context.OperationDescription</p>
                                            break;
                                        case PendingRequestKind.PgpSign:
                                            <p class="mb-1 fw-semibold">
                                                <span class="badge bg-secondary me-1">PGP</span>@(_pgpOperationLabel(req.Context.PgpOperation))
                                            </p>
                                            @if (!string.IsNullOrEmpty(req.Context.PgpKeyLabel))
                                            {
                                                <p class="mb-1 text-muted small">
                                                    Key: <code>@req.Context.PgpKeyLabel</code>
                                                </p>
                                            }
                                            <p class="mb-1 text-muted small">
                                                Hash: <code>@TruncateHash(req.Context.PayloadHashB64u ?? "")</code>
                                            </p>
                                            <p class="mb-2 text-muted small">@req.Context.OperationDescription</p>
                                            break;
                                        case PendingRequestKind.BtcSign:
                                            <p class="mb-1 fw-semibold">
                                                <span class="rec-coin-badge rec-coin-badge-btc">BTC</span>@(_btcMessageKindLabel(req.Context.BtcMessageKind))
                                            </p>
                                            <p class="mb-1 text-muted small">
                                                Network: <code>@(_btcNetworkLabel(req.Context.BtcNetwork))</code>
                                            </p>
                                            <p class="mb-1 text-muted small">
                                                Path: <code>@(req.Context.BtcDerivationPath ?? "m/84'/0'/0'/0/0")</code>
                                            </p>
                                            @if (_btcAddressByRequestId.TryGetValue(req.RequestId, out var btcDerivedAddr))
                                            {
                                                <p class="mb-1 text-muted small" style="word-break: break-all;">
                                                    Address: <code>@btcDerivedAddr</code>
                                                </p>
                                            }
                                            @if (req.Context.BtcMessageKind == BtcMessageKind.MessageSigning && !string.IsNullOrEmpty(req.Context.BtcMessageText))
                                            {
                                                <p class="mb-2 text-muted small" style="white-space: pre-wrap; word-break: break-word;">
                                                    <strong>Message:</strong> @req.Context.BtcMessageText
                                                </p>
                                            }
                                            else if (req.Context.BtcMessageKind == BtcMessageKind.Psbt && !string.IsNullOrEmpty(req.Context.BtcPsbtBase64))
                                            {
                                                <p class="mb-2 text-muted small" style="white-space: pre-wrap; word-break: break-word;">
                                                    <strong>PSBT:</strong> <code>@TruncateHash(req.Context.BtcPsbtBase64)</code>
                                                </p>
                                            }
                                            else
                                            {
                                                <p class="mb-2 text-muted small">@req.Context.OperationDescription</p>
                                            }
                                            break;
                                        case PendingRequestKind.EthSign:
                                            <p class="mb-1 fw-semibold">
                                                <span class="rec-coin-badge rec-coin-badge-eth">ETH</span>@(_ethMessageKindLabel(req.Context.EthMessageKind))
                                            </p>
                                            <p class="mb-1 text-muted small">
                                                Chain: <code>@(_ethChainLabel(req.Context.EthChainId))</code>
                                            </p>
                                            <p class="mb-1 text-muted small">
                                                Path: <code>@(req.Context.EthDerivationPath ?? "m/44'/60'/0'/0/0")</code>
                                            </p>
                                            @if (_ethAddressByRequestId.TryGetValue(req.RequestId, out var derivedAddr))
                                            {
                                                <p class="mb-1 text-muted small" style="word-break: break-all;">
                                                    Address: <code>@derivedAddr</code>
                                                </p>
                                            }
                                            @if (req.Context.EthMessageKind == EthMessageKind.PersonalSign && !string.IsNullOrEmpty(req.Context.EthMessageText))
                                            {
                                                <p class="mb-2 text-muted small" style="white-space: pre-wrap; word-break: break-word;">
                                                    <strong>Message:</strong> @req.Context.EthMessageText
                                                </p>
                                            }
                                            else if (req.Context.EthMessageKind == EthMessageKind.TypedData && !string.IsNullOrEmpty(req.Context.EthTypedDataJson))
                                            {
                                                var td = _ethTypedDataSummary(req.Context.EthTypedDataJson);
                                                <p class="mb-1 text-muted small">
                                                    <strong>Typed data (EIP-712):</strong> <code>@td.PrimaryType</code>
                                                </p>
                                                @if (!string.IsNullOrEmpty(td.DomainName))
                                                {
                                                    <p class="mb-1 text-muted small">
                                                        Domain: <code>@td.DomainName@(td.DomainVersion is null ? "" : $" v{td.DomainVersion}")</code>
                                                    </p>
                                                }
                                                @if (td.VerifyingContract is not null)
                                                {
                                                    <p class="mb-1 text-muted small" style="word-break: break-all;">
                                                        Contract: <code>@td.VerifyingContract</code>
                                                    </p>
                                                }
                                                <details class="mb-2">
                                                    <summary class="text-muted small">Show full message</summary>
                                                    <pre class="text-muted small" style="white-space: pre-wrap; word-break: break-word; max-height: 200px; overflow-y: auto;">@req.Context.EthTypedDataJson</pre>
                                                </details>
                                            }
                                            else if (req.Context.EthMessageKind == EthMessageKind.Transaction && !string.IsNullOrEmpty(req.Context.EthTransactionJson))
                                            {
                                                var tx = _ethTransactionSummary(req.Context.EthTransactionJson);
                                                @if (!string.IsNullOrEmpty(tx.To))
                                                {
                                                    <p class="mb-1 text-muted small" style="word-break: break-all;">
                                                        To: <code>@tx.To</code>
                                                    </p>
                                                }
                                                else
                                                {
                                                    <p class="mb-1 text-muted small">
                                                        <strong>Contract creation</strong>
                                                    </p>
                                                }
                                                @if (!string.IsNullOrEmpty(tx.ValueDisplay))
                                                {
                                                    <p class="mb-1 text-muted small">
                                                        Value: <code>@tx.ValueDisplay</code>
                                                    </p>
                                                }
                                                @if (!string.IsNullOrEmpty(tx.GasDisplay))
                                                {
                                                    <p class="mb-1 text-muted small">
                                                        Gas: <code>@tx.GasDisplay</code>
                                                    </p>
                                                }
                                                @if (!string.IsNullOrEmpty(tx.MaxFeeDisplay))
                                                {
                                                    <p class="mb-1 text-muted small">
                                                        Max fee: <code>@tx.MaxFeeDisplay</code>
                                                    </p>
                                                }
                                                @if (!string.IsNullOrEmpty(tx.DataPreview))
                                                {
                                                    <p class="mb-1 text-muted small" style="word-break: break-all;">
                                                        Data: <code>@tx.DataPreview</code>
                                                    </p>
                                                }
                                                <details class="mb-2">
                                                    <summary class="text-muted small">Show raw JSON</summary>
                                                    <pre class="text-muted small" style="white-space: pre-wrap; word-break: break-word; max-height: 200px; overflow-y: auto;">@req.Context.EthTransactionJson</pre>
                                                </details>
                                            }
                                            else
                                            {
                                                <p class="mb-2 text-muted small">@req.Context.OperationDescription</p>
                                            }
                                            break;
                                        default:
                                            <p class="mb-1 fw-semibold">Unknown request kind: <code>@req.Kind</code></p>
                                            <p class="mb-2 text-muted small">@req.Context.OperationDescription</p>
                                            break;
                                    }

                                    @if (_processingRequestId == req.RequestId)
                                    {
                                        <button class="btn btn-primary btn-sm w-100" disabled>
                                            <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>
                                            <span>@_processingText</span>
                                        </button>
                                    }
                                    else
                                    {
                                        <div class="d-flex gap-2">
                                            <button class="btn btn-success btn-sm flex-fill"
                                                    disabled="@(!string.IsNullOrEmpty(_processingRequestId))"
                                                    @onclick="() => HandleApproveAsync(req)">
                                                Approve
                                            </button>
                                            <button class="btn btn-outline-secondary btn-sm"
                                                    disabled="@(!string.IsNullOrEmpty(_processingRequestId))"
                                                    @onclick="() => HandleDenyAsync(req)">
                                                Deny
                                            </button>
                                        </div>
                                    }
                                </div>
                            </div>;

                            var identityReqs = _pending.Where(r => !IsTokenSigningKind(r.Kind)).ToList();
                            var tokenReqs = _pending.Where(r => IsTokenSigningKind(r.Kind)).ToList();

                        @if (identityReqs.Count > 0)
                        {
                            <section class="rec-section rec-section-identity">
                                <div class="rec-section-header">
                                    <span class="rec-section-mark">●</span>
                                    <span class="rec-section-title">Identity &amp; Access</span>
                                    <span class="rec-section-count">@identityReqs.Count</span>
                                </div>
                                @foreach (var req in identityReqs)
                                {
                                    @renderCard(req)
                                }
                            </section>
                        }

                        @if (tokenReqs.Count > 0)
                        {
                            <section class="rec-section rec-section-tokens">
                                <div class="rec-section-header">
                                    <span class="rec-section-mark">◆</span>
                                    <span class="rec-section-title">Crypto Tokens</span>
                                    <span class="rec-section-count">@tokenReqs.Count</span>
                                </div>
                                @foreach (var req in tokenReqs)
                                {
                                    @renderCard(req)
                                }
                            </section>
                        }
                    }
                </div>

                <hr class="my-3" />

                <div class="text-start small">
                    <p class="mb-2 fw-semibold d-flex justify-content-between align-items-center">
                        <span>
                            Registered phones
                            @if (_registeredPhones.Count > 0)
                            {
                                <span class="badge bg-secondary ms-1">@_registeredPhones.Count</span>
                            }
                        </span>
                        <button type="button" class="btn btn-sm btn-link p-0"
                                disabled="@_refreshingPhones"
                                @onclick="() => RefreshRegisteredPhonesAsync(CancellationToken.None)">
                            @if (_refreshingPhones)
                            {
                                <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
                            }
                            else
                            {
                                <span>Refresh</span>
                            }
                        </button>
                    </p>

                    @if (_registeredPhones.Count == 0)
                    {
                        <p class="text-muted mb-0">
                            Only this phone is registered. Pair another phone as a backup so a
                            lost device can be revoked from the surviving one.
                        </p>
                    }
                    else
                    {
                        @foreach (var other in _registeredPhones)
                        {
                            <div class="card mb-2 border-secondary-subtle">
                                <div class="card-body p-3">
                                    <p class="mb-1 fw-semibold">@other.DeviceLabel</p>
                                    <p class="mb-1 text-muted small">
                                        <code>@other.PhoneId</code>
                                    </p>
                                    <p class="mb-2 text-muted small">
                                        @other.Algorithm &mdash; paired @other.PairedAt
                                    </p>
                                    @if (_revokingPhoneId == other.PhoneId)
                                    {
                                        <button class="btn btn-danger btn-sm w-100" disabled>
                                            <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>
                                            <span>@_revokingText</span>
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-danger btn-sm w-100"
                                                disabled="@(!string.IsNullOrEmpty(_revokingPhoneId))"
                                                @onclick="() => HandleRevokeAsync(other)">
                                            Revoke
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>

                <button type="button" class="btn btn-outline-secondary w-100 mt-3" @onclick="HandleUnpairClick">
                    Unpair
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm" style="max-width: 28rem; width: 100%;">
            <div class="card-body p-4">
                <h2 class="h5 mb-3">Not paired yet</h2>
                <p class="text-muted small mb-4">
                    Enter your Recto bootloader's URL and the 6-digit pairing code.
                    Run <code>recto v0.4 register</code> on the server to mint one.
                </p>

                <div class="mb-3 text-start">
                    <label for="bootloader-url" class="form-label small">Bootloader URL</label>
                    <input id="bootloader-url"
                           type="url"
                           autocomplete="off"
                           placeholder="https://recto-bootloader.example.com"
                           class="form-control"
                           disabled="@_busy"
                           @bind="_bootloaderUrl"
                           @bind:event="oninput" />
                </div>

                <div class="mb-3 text-start">
                    <label for="pairing-code" class="form-label small">Pairing code</label>
                    <input id="pairing-code"
                           type="text"
                           inputmode="numeric"
                           maxlength="6"
                           autocomplete="off"
                           placeholder="000000"
                           class="form-control form-control-lg text-center"
                           style="letter-spacing: 0.4em; font-variant-numeric: tabular-nums;"
                           disabled="@_busy"
                           @bind="_pairingCode"
                           @bind:event="oninput" />
                </div>

                <button type="button"
                        class="btn btn-primary w-100"
                        disabled="@(!CanPair)"
                        @onclick="HandlePairClick">
                    @if (_busy)
                    {
                        <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
                        <span>@_busyText</span>
                    }
                    else
                    {
                        <span>Pair</span>
                    }
                </button>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="alert alert-danger small mt-3 mb-0 text-start" role="alert">
                        @_errorMessage
                    </div>
                }

                <p class="text-muted small mt-3 mb-0 text-start">
                    Signing algorithm: <code>@EnclaveKeys.Algorithm</code>
                </p>
            </div>
        </div>
    }

    <p class="text-muted small mt-4 mb-0">
        Running on <em>@FormFactor.GetFormFactor()</em> &mdash; <em>@FormFactor.GetPlatform()</em>
    </p>
</div>

@code {
    private const string KeyAlias = "recto.phone.identity";
    // Wave-4: alias is the suffix of the SecureStorage key
    // ("recto.phone.eth.mnemonic.{alias}"). Keep this single canonical
    // alias for the v0.5+ universal-vault first-account behavior; future
    // multi-account UI can pick alternative aliases (e.g. "trading",
    // "longterm", "thru-governance") to give each its own mnemonic.
    private const string EthKeyAlias = "default";
    // Wave-5: BTC service shares the same SecureStorage entry as ETH
    // (one mnemonic per phone, two BIP-44 trees). The alias here is
    // the same as EthKeyAlias on purpose. Future v0.6+ vault refactor
    // will collapse both into a single VaultAlias.
    private const string BtcKeyAlias = "default";
    private static readonly TimeSpan PollInterval = TimeSpan.FromSeconds(3);

    // Dev default points at the mock bootloader (phone/dev-tools/mock-bootloader.py).
    // Clear or replace with a sensible production default before public release.
    private string _bootloaderUrl = "http://127.0.0.1:8443";
    private string _pairingCode = string.Empty;
    private bool _busy;
    private string _busyText = string.Empty;
    private string? _errorMessage;
    private PairingState? _paired;

    private List<PendingRequest> _pending = new();
    // Wave-4: pre-derived ETH addresses for pending eth_sign requests,
    // keyed by request_id. Populated after every RefreshPendingAsync so
    // the render arm can display "approving with 0x..." inline without
    // doing async work inside the @switch. Each derivation runs through
    // BIP-39 + BIP-32 + secp256k1 (~2-5ms on Windows; trivial). Cleared
    // when _pending is replaced so stale entries don't leak.
    private Dictionary<string, string> _ethAddressByRequestId = new();
    // Wave-5: same pattern for BTC. Pre-derived bech32 P2WPKH addresses
    // (or Base58Check legacy / nested-SegWit when those purpose levels
    // are eventually wired) for pending btc_sign requests.
    private Dictionary<string, string> _btcAddressByRequestId = new();
    private string? _processingRequestId;
    private string _processingText = string.Empty;
    private string? _pollingError;
    private bool _retrying;
    private CancellationTokenSource? _pollCts;

    // v0.5 TOTP last-generated-code display (auto-clears after 30 s on the next render).
    private string? _lastTotpCode;
    private string? _lastTotpAlias;
    private DateTimeOffset? _lastTotpAt;
    private bool _totpCopied;

    // Round 7 phone-management.
    private List<RegisteredPhoneInfo> _registeredPhones = new();
    private bool _refreshingPhones;
    private string? _revokingPhoneId;
    private string _revokingText = string.Empty;

    private bool CanPair =>
        !_busy
        && !string.IsNullOrWhiteSpace(_bootloaderUrl)
        && _pairingCode.Length == 6
        && _pairingCode.All(char.IsDigit);

    protected override async Task OnInitializedAsync()
    {
        var current = await Pairing.GetCurrentAsync(CancellationToken.None);
        if (current.IsSuccess)
        {
            _paired = current.Value;
        }

        if (_paired is not null)
        {
            RestorePin(_paired);
            StartPolling();
            await RefreshRegisteredPhonesAsync(CancellationToken.None);
        }
    }

    private async Task HandlePairClick()
    {
        _errorMessage = null;
        _busy = true;
        try
        {
            await SetBusyTextAsync("Identifying phone...");
            var phoneIdResult = await Pairing.GetOrCreatePhoneIdAsync(CancellationToken.None);
            if (phoneIdResult.IsFailure)
            {
                _errorMessage = phoneIdResult.Error.Message;
                return;
            }
            var phoneId = phoneIdResult.Value;

            await SetBusyTextAsync("Contacting bootloader...");
            var challengeResult = await BootloaderClient.GetRegistrationChallengeAsync(
                _bootloaderUrl, _pairingCode, CancellationToken.None);
            if (challengeResult.IsFailure)
            {
                _errorMessage = challengeResult.Error.Message;
                return;
            }
            var challenge = challengeResult.Value;

            await SetBusyTextAsync("Preparing identity key...");
            var existsResult = await EnclaveKeys.KeyExistsAsync(KeyAlias, CancellationToken.None);
            EnclavePublicKey publicKey;
            if (existsResult.IsSuccess && existsResult.Value)
            {
                var pubResult = await EnclaveKeys.GetPublicKeyAsync(KeyAlias, CancellationToken.None);
                if (pubResult.IsFailure)
                {
                    _errorMessage = pubResult.Error.Message;
                    return;
                }
                publicKey = pubResult.Value;
            }
            else
            {
                var genResult = await EnclaveKeys.GenerateAsync(KeyAlias, CancellationToken.None);
                if (genResult.IsFailure)
                {
                    _errorMessage = genResult.Error.Message;
                    return;
                }
                publicKey = genResult.Value;
            }

            await SetBusyTextAsync("Awaiting biometric approval...");
            var challengeBytes = Base64UrlDecode(challenge.ChallengeB64u);
            var signResult = await EnclaveKeys.SignAsync(KeyAlias, challengeBytes, CancellationToken.None);
            if (signResult.IsFailure)
            {
                _errorMessage = signResult.Error.Message;
                return;
            }

            await SetBusyTextAsync("Fetching push token...");
            // Best-effort: a push-token failure is non-fatal -- pairing still
            // works, the bootloader just falls back to the 3s poll cycle for
            // this phone. Windows / Mac Catalyst dev hosts return null
            // (NoOpPushTokenService); Android / iOS return real tokens.
            string? pushToken = null;
            string? pushPlatform = null;
            try
            {
                var pushResult = await PushTokens.GetTokenAsync(CancellationToken.None);
                if (pushResult.IsSuccess && pushResult.Value is not null)
                {
                    pushToken = pushResult.Value.Token;
                    pushPlatform = pushResult.Value.Platform;
                }
            }
            catch { /* swallow -- pairing must not fail because push wasn't available */ }

            await SetBusyTextAsync("Registering with bootloader...");
            var deviceLabel = $"Recto / {FormFactor.GetFormFactor()}";
            var request = new RegistrationRequest(
                PhoneId: phoneId,
                DeviceLabel: deviceLabel,
                PublicKeyB64u: Base64UrlEncode(publicKey.PublicKey),
                SupportedAlgorithms: new[] { publicKey.Algorithm },
                V04Protocol: V04Protocol.Version,
                RegistrationProof: new RegistrationProof(
                    Challenge: challenge.ChallengeB64u,
                    SignatureB64u: Base64UrlEncode(signResult.Value)),
                PushToken: pushToken,
                PushPlatform: pushPlatform);

            var registerResult = await BootloaderClient.RegisterAsync(
                _bootloaderUrl, request, CancellationToken.None);
            if (registerResult.IsFailure)
            {
                _errorMessage = registerResult.Error.Message;
                return;
            }

            string? capturedPin = TryCaptureBootloaderPin(_bootloaderUrl);

            var registration = registerResult.Value;
            var pairedState = new PairingState(
                PhoneId: registration.PhoneId,
                BootloaderId: registration.BootloaderId,
                BootloaderUrl: _bootloaderUrl,
                ManagedSecrets: registration.ManagedSecrets
                    .Select(s => new ManagedSecretRef(s.Service, s.Secret, s.Algorithm))
                    .ToArray(),
                PairedAt: DateTimeOffset.UtcNow,
                BootloaderSpkiPin: capturedPin);

            var saveResult = await Pairing.SaveAsync(pairedState, CancellationToken.None);
            if (saveResult.IsFailure)
            {
                _errorMessage = saveResult.Error.Message;
                return;
            }

            _paired = pairedState;
            StartPolling();
            await RefreshRegisteredPhonesAsync(CancellationToken.None);
        }
        finally
        {
            _busy = false;
            _busyText = string.Empty;
            StateHasChanged();
        }
    }

    private async Task HandleUnpairClick()
    {
        StopPolling();
        if (_paired is not null)
        {
            ClearPin(_paired.BootloaderUrl);
        }
        var clear = await Pairing.ClearAsync(CancellationToken.None);
        if (clear.IsSuccess)
        {
            _paired = null;
            _pending.Clear();
            _registeredPhones.Clear();
            _bootloaderUrl = "http://127.0.0.1:8443";
            _pairingCode = string.Empty;
            _errorMessage = null;
            _pollingError = null;
            _lastTotpCode = null;
            _lastTotpAlias = null;
            _lastTotpAt = null;
        }
    }

    // --- Approve / deny dispatchers (unchanged from round 6) ---

    private async Task HandleApproveAsync(PendingRequest req)
    {
        if (_paired is null) return;
        _processingRequestId = req.RequestId;
        StateHasChanged();

        try
        {
            switch (req.Kind)
            {
                case PendingRequestKind.SingleSign:
                    await ApproveSingleSignAsync(req);
                    break;
                case PendingRequestKind.TotpProvision:
                    await ApproveTotpProvisionAsync(req);
                    break;
                case PendingRequestKind.TotpGenerate:
                    await ApproveTotpGenerateAsync(req);
                    break;
                case PendingRequestKind.SessionIssuance:
                    await ApproveSessionIssuanceAsync(req);
                    break;
                case PendingRequestKind.WebAuthnAssert:
                    await ApproveWebAuthnAssertAsync(req);
                    break;
                case PendingRequestKind.Pkcs11Sign:
                case PendingRequestKind.PgpSign:
                    // PKCS#11 and PGP both reuse the single_sign signing
                    // path -- they're just labeled differently in the UI
                    // so the operator sees the right context for what
                    // they're approving (an SSH login vs an arbitrary
                    // sign vs a git commit signature).
                    await ApproveSingleSignAsync(req);
                    break;
                case PendingRequestKind.EthSign:
                    await ApproveEthSignAsync(req);
                    break;
                case PendingRequestKind.BtcSign:
                    await ApproveBtcSignAsync(req);
                    break;
                default:
                    _pollingError = $"Cannot approve unknown request kind '{req.Kind}'.";
                    break;
            }
        }
        finally
        {
            _processingRequestId = null;
            _processingText = string.Empty;
            StateHasChanged();
        }
    }

    private async Task ApproveBtcSignAsync(PendingRequest req)
    {
        // Validate BTC-specific context before either crypto path runs.
        // Today only message_signing is wired end-to-end on the phone
        // side; psbt earns its own approval method when BIP-174 lands.
        var msgKind = req.Context.BtcMessageKind;
        if (string.IsNullOrEmpty(msgKind))
        {
            _pollingError = "btc_sign request missing btc_message_kind.";
            return;
        }
        if (msgKind != BtcMessageKind.MessageSigning)
        {
            _pollingError = $"btc_sign kind '{msgKind}' is not yet implemented; only message_signing is wired today.";
            return;
        }
        if (string.IsNullOrEmpty(req.Context.BtcMessageText))
        {
            _pollingError = "btc_sign message_signing request missing btc_message_text.";
            return;
        }
        if (string.IsNullOrEmpty(req.Context.PayloadHashB64u))
        {
            _pollingError = "btc_sign request missing payload_hash_b64u (Ed25519 envelope binding).";
            return;
        }

        var derivationPath = string.IsNullOrEmpty(req.Context.BtcDerivationPath)
            ? "m/84'/0'/0'/0/0"
            : req.Context.BtcDerivationPath!;
        var network = string.IsNullOrEmpty(req.Context.BtcNetwork)
            ? "mainnet"
            : req.Context.BtcNetwork!;

        _processingText = "Signing with BTC key...";
        StateHasChanged();
        await Task.Yield();

        // Phone produces TWO signatures (same shape as eth_sign):
        //   (a) BIP-137 compact secp256k1 signature over the BIP-137
        //       hash of the message, returned in
        //       RespondRequest.BtcSignatureBase64. Opaque to the
        //       bootloader; consumed by the smart contract / off-chain
        //       verifier / wallet performing on-chain verification.
        //   (b) Ed25519 over the bootloader-supplied payload_hash_b64u,
        //       returned in RespondRequest.SignatureB64u. Proves the
        //       response came from the paired phone — same envelope
        //       eth_sign / single_sign use.
        var signResult = await BtcSigner.SignMessageAsync(
            BtcKeyAlias, derivationPath, network, req.Context.BtcMessageText!, CancellationToken.None);
        if (signResult.IsFailure)
        {
            _pollingError = signResult.Error.Message;
            return;
        }
        var compactSigBase64 = signResult.Value;

        byte[] payloadHash;
        try { payloadHash = Base64UrlDecode(req.Context.PayloadHashB64u!); }
        catch (Exception ex)
        {
            _pollingError = $"Could not decode payload hash: {ex.Message}";
            return;
        }
        _processingText = "Awaiting biometric...";
        StateHasChanged();
        var enclaveSignResult = await EnclaveKeys.SignAsync(KeyAlias, payloadHash, CancellationToken.None);
        if (enclaveSignResult.IsFailure)
        {
            _pollingError = enclaveSignResult.Error.Message;
            return;
        }

        _processingText = "Sending response...";
        StateHasChanged();
        var respondReq = new RespondRequest(
            PhoneId: _paired!.PhoneId,
            Decision: RespondDecision.Approved,
            SignatureB64u: Base64UrlEncode(enclaveSignResult.Value),
            BtcSignatureBase64: compactSigBase64);
        var respondResult = await BootloaderClient.RespondAsync(
            _paired.BootloaderUrl, req.RequestId, respondReq, CancellationToken.None);
        if (respondResult.IsFailure)
        {
            _pollingError = respondResult.Error.Message;
            return;
        }
        await RefreshPendingAsync(CancellationToken.None);
    }

    private async Task ApproveEthSignAsync(PendingRequest req)
    {
        // Validate ETH-specific context before either crypto path runs.
        // All three message kinds are now wired end-to-end: personal_sign
        // (EIP-191), typed_data (EIP-712), and transaction (EIP-1559 raw
        // signed bytes ready for eth_sendRawTransaction).
        var msgKind = req.Context.EthMessageKind;
        if (string.IsNullOrEmpty(msgKind))
        {
            _pollingError = "eth_sign request missing eth_message_kind.";
            return;
        }
        if (msgKind != EthMessageKind.PersonalSign
            && msgKind != EthMessageKind.TypedData
            && msgKind != EthMessageKind.Transaction)
        {
            _pollingError = $"eth_sign kind '{msgKind}' is not recognized.";
            return;
        }
        if (msgKind == EthMessageKind.PersonalSign && string.IsNullOrEmpty(req.Context.EthMessageText))
        {
            _pollingError = "eth_sign personal_sign request missing eth_message_text.";
            return;
        }
        if (msgKind == EthMessageKind.TypedData && string.IsNullOrEmpty(req.Context.EthTypedDataJson))
        {
            _pollingError = "eth_sign typed_data request missing eth_typed_data_json.";
            return;
        }
        if (msgKind == EthMessageKind.Transaction && string.IsNullOrEmpty(req.Context.EthTransactionJson))
        {
            _pollingError = "eth_sign transaction request missing eth_transaction_json.";
            return;
        }
        if (string.IsNullOrEmpty(req.Context.PayloadHashB64u))
        {
            _pollingError = "eth_sign request missing payload_hash_b64u (Ed25519 envelope binding).";
            return;
        }

        var derivationPath = string.IsNullOrEmpty(req.Context.EthDerivationPath)
            ? "m/44'/60'/0'/0/0"
            : req.Context.EthDerivationPath!;

        _processingText = msgKind switch
        {
            EthMessageKind.PersonalSign => "Signing with ETH key (EIP-191)...",
            EthMessageKind.TypedData => "Signing with ETH key (EIP-712)...",
            EthMessageKind.Transaction => "Signing with ETH key (EIP-1559)...",
            _ => "Signing with ETH key...",
        };
        StateHasChanged();
        await Task.Yield();

        // Phone produces TWO signatures:
        //   (a) secp256k1 over the kind-specific digest (EIP-191 hash for
        //       personal_sign, EIP-712 hash for typed_data, EIP-1559 hash
        //       for transaction). For personal_sign + typed_data the
        //       result is 65-byte r||s||v with v ∈ {27, 28}; for
        //       transaction the result is the FULL raw signed-tx bytes
        //       (0x02 || rlp([fields..., yParity, r, s])) ready for
        //       eth_sendRawTransaction. All three return as
        //       RespondRequest.EthSignatureRsv (the field name is a
        //       slight misnomer for transaction's case, but the wire
        //       protocol pre-dates that distinction; bootloader does
        //       structure-only validation, so it forwards opaquely).
        //   (b) Ed25519 over the bootloader-supplied payload_hash_b64u,
        //       returned in RespondRequest.SignatureB64u. Proves the
        //       response came from the paired phone -- same envelope
        //       single_sign uses.
        Result<string> signResult;
        if (msgKind == EthMessageKind.PersonalSign)
        {
            signResult = await EthSigner.SignPersonalSignAsync(
                EthKeyAlias, derivationPath, req.Context.EthMessageText!, CancellationToken.None);
        }
        else if (msgKind == EthMessageKind.TypedData)
        {
            signResult = await EthSigner.SignTypedDataAsync(
                EthKeyAlias, derivationPath, req.Context.EthTypedDataJson!, CancellationToken.None);
        }
        else // Transaction
        {
            signResult = await EthSigner.SignTransactionAsync(
                EthKeyAlias, derivationPath, req.Context.EthTransactionJson!, CancellationToken.None);
        }
        if (signResult.IsFailure)
        {
            _pollingError = signResult.Error.Message;
            return;
        }
        var rsvHex = signResult.Value;

        byte[] payloadHash;
        try { payloadHash = Base64UrlDecode(req.Context.PayloadHashB64u!); }
        catch (Exception ex)
        {
            _pollingError = $"Could not decode payload hash: {ex.Message}";
            return;
        }
        _processingText = "Awaiting biometric...";
        StateHasChanged();
        var enclaveSignResult = await EnclaveKeys.SignAsync(KeyAlias, payloadHash, CancellationToken.None);
        if (enclaveSignResult.IsFailure)
        {
            _pollingError = enclaveSignResult.Error.Message;
            return;
        }

        _processingText = "Sending response...";
        StateHasChanged();
        var respondReq = new RespondRequest(
            PhoneId: _paired!.PhoneId,
            Decision: RespondDecision.Approved,
            SignatureB64u: Base64UrlEncode(enclaveSignResult.Value),
            EthSignatureRsv: rsvHex);
        var respondResult = await BootloaderClient.RespondAsync(
            _paired.BootloaderUrl, req.RequestId, respondReq, CancellationToken.None);
        if (respondResult.IsFailure)
        {
            _pollingError = respondResult.Error.Message;
            return;
        }
        await RefreshPendingAsync(CancellationToken.None);
    }

