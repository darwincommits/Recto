<?xml version="1.0" encoding="utf-8"?>
<!--
  Recto network security config. Default-deny cleartext for arbitrary domains;
  whitelist-allow cleartext only for localhost-style hosts so the dev workflow
  (mock bootloader on Windows reachable via `adb reverse tcp:8443 tcp:8443`)
  works without opening cleartext traffic to the public internet.

  Production bootloaders should always be HTTPS; this config applies only to
  dev-loop traffic to 127.0.0.1 / localhost / the standard Android emulator
  alias 10.0.2.2.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
